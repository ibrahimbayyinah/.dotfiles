#!/bin/sh
# pdfnup - Make N-up PDFs using system pdfjam/pdflatex (POSIX sh)
# Supports multiple input PDFs in one call.

usage() {
  echo "Usage: ${0##*/} [-n ROWS] [-c COLS] [-s N] [-L] input1.pdf [input2.pdf ...]" >&2
  echo "  -n ROWS  Rows per sheet (default: 3)" >&2
  echo "  -c COLS  Columns per sheet (default: 1)" >&2
  echo "  -s N     Square layout NxN (sets COLS=N and ROWS=N)" >&2
  echo "  -L       Landscape" >&2
  exit 2
}

is_posint() {
  case "$1" in
    ''|*[!0-9]*) return 1 ;;
  esac
  [ "$1" -gt 0 ] 2>/dev/null
}

cols=1
rows=3
landscape=0

while getopts "n:c:s:Lh" opt; do
  case "$opt" in
    n) rows=$OPTARG ;;
    c) cols=$OPTARG ;;
    s) cols=$OPTARG; rows=$OPTARG ;;
    L) landscape=1 ;;
    h|\?) usage ;;
  esac
done
shift $((OPTIND - 1))

[ $# -ge 1 ] || usage

is_posint "$cols" || { echo "Error: -c must be a positive integer" >&2; exit 1; }
is_posint "$rows" || { echo "Error: -n must be a positive integer" >&2; exit 1; }

perpage=$((cols * rows))

PDFJAM=/usr/bin/pdfjam
PDFLATEX=/usr/bin/pdflatex

[ -x "$PDFJAM" ] || { echo "Error: not found/executable: $PDFJAM" >&2; exit 1; }
[ -x "$PDFLATEX" ] || { echo "Error: not found/executable: $PDFLATEX" >&2; exit 1; }

fail=0

for in do
  # Must be a readable PDF file
  if [ ! -r "$in" ]; then
    echo "Error: cannot read: $in" >&2
    fail=1
    continue
  fi
  case "$in" in
    *.pdf|*.PDF) ;;
    *)
      echo "Error: input must be a PDF (*.pdf): $in" >&2
      fail=1
      continue
      ;;
  esac

  dir=${in%/*}
  base=${in##*/}
  name=${base%.*}
  ext=${base##*.}

  out="${name}-${perpage}s.${ext}"
  if [ "$dir" != "$in" ]; then
    out="$dir/$out"
  fi

  # Build args safely
  set -- --nup "${cols}x${rows}" --paper a4paper
  [ "$landscape" -eq 1 ] && set -- "$@" --landscape
  set -- "$@" --outfile "$out" -- "$in"

  echo "Processing: $in -> $out" >&2
  if ! PATH=/usr/bin:$PATH PDFJAM_PDFLATEX=$PDFLATEX "$PDFJAM" "$@"; then
    echo "Error: failed: $in" >&2
    fail=1
    continue
  fi
done

exit "$fail"
